{
  "validation_rules": {
    "confidence_threshold": {
      "base": 0.5,
      "dynamic_range": [0.5, 0.6],
      "adjustment_factors": ["contributor_experience", "system_stability", "review_density"],
      "experimental": {
        "value": 0.6,
        "period": "2026-06-07 to 2026-06-13"
      }
    },
    "new_contributor_policy": {
      "mode": "independent_category",
      "new_contributor_mode": true,
      "default_review_history": null,
      "fallback_review_history": 0.7,
      "weight_adjustment": {
        "self_confidence": 0.57,
        "validation_score": 0.43
      }
    }
  },
  "metrics": {
    "coherence_index": {
      "weights": {
        "jaccard_similarity": 0.6,
        "priority": 0.2,
        "recency": 0.2
      }
    },
    "reliability_index": {
      "weights": {
        "effective_confidence": 0.5,
        "review_history": 0.5
      }
    }
  },
  "evidence_levels": {
    "declared": "صرح بها صاحبها مباشرة",
    "reported": "نقلها وسيط عن صاحبها",
    "verified": "تم التحقق من صحتها عبر مصدر مستقل"
  }
}