{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SOSHAI_Contribution_Schema_v1.1",
  "version": "1.1.0",
  "type": "object",
  "properties": {
    "standard_schema": {
      "type": "object",
      "properties": {
        "fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compact_schema": {
      "type": "object",
      "properties": {
        "max_total_chars": { "type": "integer", "maximum": 500 },
        "fields": {
          "type": "object",
          "properties": {
            "decision": { "type": "string" },
            "gap_identified": { "type": "string" },
            "next_step": { "type": "string" }
          }
        }
      }
    }
  }
}
